{% liquid
  assign content_max_width = section.settings.content_max_width | default: "unset"
  assign slide_count = section.blocks.size
%}

<style>
  .ws-recommended-carousel-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_pc }};
    padding-bottom: {{ section.settings.padding_bottom_pc }};
    margin-top: {{ section.settings.margin_top_pc }};
    margin-bottom: {{ section.settings.margin_bottom_pc }};
  }

  .ws-recommended-carousel-{{ section.id }} .ws-recommended-carousel__inner {
    max-width: {{ content_max_width }};
  }

  @media (max-width: 768px) {
    .ws-recommended-carousel-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }};
      padding-bottom: {{ section.settings.padding_bottom_mobile }};
      margin-top: {{ section.settings.margin_top_mobile }};
      margin-bottom: {{ section.settings.margin_bottom_mobile }};
    }
  }
</style>

<div
  class="section color-{{ section.settings.color_scheme }} ws-recommended-carousel ws-recommended-carousel-{{ section.id }}"
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <ws-recommended-carousel
    class="ws-recommended-carousel__shell"
    {% if section.settings.section_id != blank %}
      id="{{ section.settings.section_id | escape }}"
    {% endif %}
  >
    <div class="ws-recommended-carousel__inner">
      <div class="ws-recommended-carousel__layout">
        <div class="ws-recommended-carousel__content">
          {% if slide_count > 0 %}
            <div class="ws-recommended-carousel__content-panels">
              {% for block in section.blocks %}
                <div
                  class="ws-recommended-carousel__content-panel{% if forloop.first %} is-active{% endif %}"
                  ref="contentPanels[]"
                  data-panel-index="{{ forloop.index0 }}"
                  {% unless forloop.first %}
                    hidden
                  {% endunless %}
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.eyebrow != blank %}
                    <p class="ws-recommended-carousel__eyebrow">{{ block.settings.eyebrow }}</p>
                  {% endif %}

                  {% if block.settings.title != blank or block.settings.subtitle != blank %}
                    <header class="ws-recommended-carousel__header">
                      {% if block.settings.title != blank %}
                        <h2 class="ws-recommended-carousel__title">{{ block.settings.title }}</h2>
                      {% endif %}
                      {% if block.settings.subtitle != blank %}
                        <p class="ws-recommended-carousel__subtitle">{{ block.settings.subtitle }}</p>
                      {% endif %}
                    </header>
                  {% endif %}

                  {% if block.settings.button_label != blank %}
                    <div class="ws-recommended-carousel__actions">
                      <a
                        class="ws-recommended-carousel__button"
                        {% if block.settings.button_link != blank %}
                          href="{{ block.settings.button_link }}"
                        {% else %}
                          role="link"
                          aria-disabled="true"
                        {% endif %}
                        {% if block.settings.button_open_new_tab %}
                          target="_blank"
                          rel="noopener noreferrer"
                        {% endif %}
                      >
                        {{ block.settings.button_label }}
                      </a>
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>

            <div
              class="ws-recommended-carousel__pagination"
              role="tablist"
              aria-label="{{ 'accessibility.slideshow' | t }}"
            >
              {% for block in section.blocks %}
                <button
                  type="button"
                  class="ws-recommended-carousel__dot{% if forloop.first %} is-active{% endif %}"
                  ref="dots[]"
                  aria-label="{{ 'accessibility.slide_status' | t: index: forloop.index, length: slide_count }}"
                  aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                ></button>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {% if slide_count > 0 %}
          <div class="ws-recommended-carousel__media-panel">
            <div class="ws-recommended-carousel__track" ref="track">
              {% for block in section.blocks %}
                <div
                  class="ws-recommended-carousel__slide"
                  ref="slides[]"
                  data-slide-index="{{ forloop.index0 }}"
                >
                  {% if block.settings.media_type == 'video' and block.settings.video != blank %}
                    {{
                      block.settings.video
                      | video_tag:
                        image_size: '1600x',
                        autoplay: true,
                        loop: true,
                        muted: true,
                        playsinline: true,
                        controls: false,
                        class: 'ws-recommended-carousel__media'
                    }}
                  {% elsif block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: 1600
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 800, 1000, 1200, 1600',
                        sizes: '(min-width: 750px) 42vw, 78vw',
                        class: 'ws-recommended-carousel__media',
                        alt: block.settings.image.alt
                    }}
                  {% else %}
                    <div class="ws-recommended-carousel__media ws-recommended-carousel__media--placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </ws-recommended-carousel>
</div>

{{ 'ws-recommended-carousel.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ws-recommended-carousel.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "Recommended Carousel",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "ws-recommended-slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "button_open_new_tab",
          "label": "Open in new tab",
          "default": false
        },
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Video"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "visible_if": "{{ block.settings.media_type == 'video' }}"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Section Shell"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "Custom HTML ID for anchor links"
    },
    {
      "type": "text",
      "id": "content_max_width",
      "label": "Content max width",
      "default": "unset"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "text",
      "id": "padding_top_pc",
      "label": "PC padding top",
      "default": "36px"
    },
    {
      "type": "text",
      "id": "padding_bottom_pc",
      "label": "PC padding bottom",
      "default": "36px"
    },
    {
      "type": "text",
      "id": "padding_top_mobile",
      "label": "Mobile padding top",
      "default": "18px"
    },
    {
      "type": "text",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom",
      "default": "18px"
    },
    {
      "type": "text",
      "id": "margin_top_pc",
      "label": "PC margin top",
      "default": "0"
    },
    {
      "type": "text",
      "id": "margin_bottom_pc",
      "label": "PC margin bottom",
      "default": "0"
    },
    {
      "type": "text",
      "id": "margin_top_mobile",
      "label": "Mobile margin top",
      "default": "0"
    },
    {
      "type": "text",
      "id": "margin_bottom_mobile",
      "label": "Mobile margin bottom",
      "default": "0"
    }
  ],
  "presets": [
    {
      "name": "Recommended Carousel",
      "category": "Custom Sections",
      "blocks": [
        {
          "type": "ws-recommended-slide",
          "settings": {
            "eyebrow": "MARINE SCIENCE ADVOCATE",
            "title": "Recommended by CAMERON SHAW",
            "subtitle": "Protecting oceans through science and education.",
            "media_type": "image"
          }
        },
        {
          "type": "ws-recommended-slide",
          "settings": {
            "eyebrow": "MARINE BIOLOGIST / SCIENTIFIC DIVER",
            "title": "Recommended by JANICE MARQUEZ DE LA PLATA",
            "subtitle": "Advocating for ocean protection and mindful living by the sea.",
            "media_type": "image"
          }
        }
      ]
    }
  ]
}
{% endschema %}
