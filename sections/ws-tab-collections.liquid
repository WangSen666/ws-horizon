<style>
  .ws-tab-collections-{{ section.id }} {
    --ws-tab-collections-bg: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_pc }};
    padding-bottom: {{ section.settings.padding_bottom_pc }};
    margin-top: {{ section.settings.margin_top_pc }};
    margin-bottom: {{ section.settings.margin_bottom_pc }};
  }

  @media (max-width: 749px) {
    .ws-tab-collections-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }};
      padding-bottom: {{ section.settings.padding_bottom_mobile }};
      margin-top: {{ section.settings.margin_top_mobile }};
      margin-bottom: {{ section.settings.margin_bottom_mobile }};
    }
  }
</style>

<div
  class="section section--full-width ws-tab-collections ws-tab-collections-{{ section.id }}"
  {% if section.settings.section_id != blank %}
    id="{{ section.settings.section_id | escape }}"
  {% endif %}
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <ws-tab-collections class="ws-tab-collections__shell">
    <div class="ws-tab-collections__inner">
      <div class="ws-tab-collections__layout">
        {% if section.settings.heading != blank %}
          <div class="ws-tab-collections__header">
            <h2 class="ws-tab-collections__heading">{{ section.settings.heading }}</h2>
          </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="ws-tab-collections__toolbar">
            <div class="ws-tab-collections__tabs" role="tablist" aria-label="{{ section.settings.heading | default: 'Collections' }}">
              {% for block in section.blocks %}
                <button
                  type="button"
                  class="ws-tab-collections__tab{% if forloop.first %} is-active{% endif %}"
                  ref="tabButtons[]"
                  role="tab"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-controls="ws-tab-collections-panel-{{ section.id }}-{{ block.id }}"
                  id="ws-tab-collections-tab-{{ section.id }}-{{ block.id }}"
                  data-tab-index="{{ forloop.index0 }}"
                >
                  {{ block.settings.tab_title | default: 'Tab' }}
                </button>
              {% endfor %}
            </div>

            <div class="ws-tab-collections__view-more-wrap">
              {% for block in section.blocks %}
                {% if block.settings.view_more_link != blank %}
                  <a
                    class="ws-tab-collections__view-more{% if forloop.first %} is-active{% endif %}"
                    ref="viewMoreLinks[]"
                    href="{{ block.settings.view_more_link }}"
                    {% unless forloop.first %}
                      hidden
                    {% endunless %}
                  >
                    {{ section.settings.view_more_label | default: 'VIEW MORE' }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>

          <div class="ws-tab-collections__panels">
            {% for block in section.blocks %}
              {% liquid
                assign product_limit = block.settings.max_products | default: section.settings.products_per_group
                assign collection_obj = block.settings.collection
                assign banner_link = block.settings.banner_link
                if banner_link == blank and collection_obj != blank
                  assign banner_link = collection_obj.url
                endif
                assign product_count = 0
                if collection_obj != blank
                  assign product_count = collection_obj.products_count
                endif
              %}
              <div
                class="ws-tab-collections__panel{% if forloop.first %} is-active{% endif %}"
                ref="tabPanels[]"
                role="tabpanel"
                id="ws-tab-collections-panel-{{ section.id }}-{{ block.id }}"
                aria-labelledby="ws-tab-collections-tab-{{ section.id }}-{{ block.id }}"
                {% unless forloop.first %}
                  hidden
                {% endunless %}
                {{ block.shopify_attributes }}
              >
                <div class="ws-tab-collections__group">
                  <div class="ws-tab-collections__track-wrap">
                    <div class="ws-tab-collections__track" ref="tracks[]">
                      <article class="ws-tab-collections__slide ws-tab-collections__slide--featured">
                        <a
                          class="ws-tab-collections__featured"
                          {% if banner_link != blank %}
                            href="{{ banner_link }}"
                          {% else %}
                            role="link"
                            aria-disabled="true"
                          {% endif %}
                        >
                          {% if block.settings.banner_image != blank %}
                            {{
                              block.settings.banner_image
                              | image_url: width: 1200
                              | image_tag:
                                loading: 'lazy',
                                widths: '360, 540, 720, 960, 1200',
                                sizes: '(min-width: 1024px) 33vw, 100vw',
                                class: 'ws-tab-collections__featured-image',
                                alt: block.settings.banner_image.alt
                            }}
                          {% elsif collection_obj != blank and collection_obj.image %}
                            {{
                              collection_obj.image
                              | image_url: width: 1200
                              | image_tag:
                                loading: 'lazy',
                                widths: '360, 540, 720, 960, 1200',
                                sizes: '(min-width: 1024px) 33vw, 100vw',
                                class: 'ws-tab-collections__featured-image',
                                alt: collection_obj.image.alt
                            }}
                          {% else %}
                            <div class="ws-tab-collections__featured-image ws-tab-collections__featured-image--placeholder">
                              {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder' }}
                            </div>
                          {% endif %}
                          <div class="ws-tab-collections__featured-content">
                            {% if product_count > 0 %}
                              <p class="ws-tab-collections__featured-count">{{ product_count }} products</p>
                            {% endif %}
                            <p class="ws-tab-collections__featured-title">
                              <strong>{{ block.settings.banner_title | default: collection_obj.title | default: 'Collection' }} &gt;&gt;</strong>
                            </p>
                          </div>
                        </a>
                      </article>

                      {% if collection_obj != blank and collection_obj.products_count > 0 %}
                        {% for product in collection_obj.products limit: product_limit %}
                          {% assign hover_media = product.media[1] %}
                          <article class="ws-tab-collections__slide ws-tab-collections__slide--product">
                            <div class="ws-tab-collections__card">
                              <div class="ws-tab-collections__card-media-wrap">
                                <a class="ws-tab-collections__card-media" href="{{ product.url }}">
                                  {% if product.featured_media %}
                                    {{
                                      product.featured_media
                                      | image_url: width: 800
                                      | image_tag:
                                        loading: 'lazy',
                                        widths: '200, 300, 400, 500, 600, 800',
                                        sizes: '(min-width: 1024px) 25vw, 78vw',
                                        class: 'ws-tab-collections__card-image ws-tab-collections__card-image--primary',
                                        alt: product.featured_media.alt
                                    }}
                                    {% if hover_media %}
                                      {{
                                        hover_media
                                        | image_url: width: 800
                                        | image_tag:
                                          loading: 'lazy',
                                          widths: '200, 300, 400, 500, 600, 800',
                                          sizes: '(min-width: 1024px) 25vw, 78vw',
                                          class: 'ws-tab-collections__card-image ws-tab-collections__card-image--hover',
                                          alt: hover_media.alt
                                      }}
                                    {% endif %}
                                  {% else %}
                                    <div class="ws-tab-collections__card-image ws-tab-collections__card-image--placeholder">
                                      {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder' }}
                                    </div>
                                  {% endif %}
                                </a>
                                <a class="ws-tab-collections__quick-buy" href="{{ product.url }}">Quick Buy</a>
                              </div>
                              <div class="ws-tab-collections__card-body">
                                <a class="ws-tab-collections__card-title" href="{{ product.url }}">{{ product.title }}</a>
                                <div class="ws-tab-collections__card-price">
                                  {% render 'price', product_resource: product %}
                                </div>
                              </div>
                            </div>
                          </article>
                        {% endfor %}
                      {% else %}
                        {% for i in (1..product_limit) %}
                          <article class="ws-tab-collections__slide ws-tab-collections__slide--product">
                            <div class="ws-tab-collections__card ws-tab-collections__card--placeholder">
                              <div class="ws-tab-collections__card-media-wrap">
                                <div class="ws-tab-collections__card-image ws-tab-collections__card-image--placeholder">
                                  {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder' }}
                                </div>
                              </div>
                              <div class="ws-tab-collections__card-body">
                                <p class="ws-tab-collections__card-title">{{ 'content.product_card_placeholder' | t }}</p>
                                <div class="ws-tab-collections__card-price">
                                  {% render 'price', product_resource: null %}
                                </div>
                              </div>
                            </div>
                          </article>
                        {% endfor %}
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="ws-tab-collections__empty">请先添加 Tab block。</p>
        {% endif %}
      </div>
    </div>
  </ws-tab-collections>
</div>

{{ 'ws-tab-collections.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ws-tab-collections.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "Tab Collections",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab title",
          "default": "Best Sellers"
        },
        {
          "type": "url",
          "id": "view_more_link",
          "label": "VIEW MORE link"
        },
        {
          "type": "header",
          "content": "Featured collection"
        },
        {
          "type": "text",
          "id": "banner_title",
          "label": "Banner title",
          "default": "Handpicked For You"
        },
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner image"
        },
        {
          "type": "url",
          "id": "banner_link",
          "label": "Banner link"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "range",
          "id": "max_products",
          "label": "Products in row",
          "min": 2,
          "max": 12,
          "step": 1,
          "default": 6
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending This Season"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f8"
    },
    {
      "type": "text",
      "id": "view_more_label",
      "label": "VIEW MORE label",
      "default": "VIEW MORE"
    },
    {
      "type": "range",
      "id": "products_per_group",
      "label": "Default products per group",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "padding_top_pc",
      "label": "PC padding top",
      "default": "80px"
    },
    {
      "type": "text",
      "id": "padding_bottom_pc",
      "label": "PC padding bottom",
      "default": "60px"
    },
    {
      "type": "text",
      "id": "padding_top_mobile",
      "label": "Mobile padding top",
      "default": "40px"
    },
    {
      "type": "text",
      "id": "padding_bottom_mobile",
      "label": "Mobile padding bottom",
      "default": "32px"
    },
    {
      "type": "text",
      "id": "margin_top_pc",
      "label": "PC margin top",
      "default": "0"
    },
    {
      "type": "text",
      "id": "margin_bottom_pc",
      "label": "PC margin bottom",
      "default": "0"
    },
    {
      "type": "text",
      "id": "margin_top_mobile",
      "label": "Mobile margin top",
      "default": "0"
    },
    {
      "type": "text",
      "id": "margin_bottom_mobile",
      "label": "Mobile margin bottom",
      "default": "0"
    }
  ],
  "presets": [
    {
      "name": "Tab Collections",
      "category": "Custom Sections",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_title": "Best Sellers",
            "banner_title": "Handpicked For You"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_title": "Recommend",
            "banner_title": "Ocean New Drops"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_title": "New Arrivals",
            "banner_title": "New Drops every 15th"
          }
        }
      ]
    }
  ]
}
{% endschema %}
